{
  "name": "@gp/grampanchayat-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test:phase1": "node --import tsx scripts/phase1-smoke.ts",
    "test:phase3": "node --import tsx scripts/phase3-smoke.ts",
    "smoke:n10": "node --import tsx scripts/smoke-n10-create.ts",
    "seed:demo": "node --import tsx scripts/seed-demo-gp.ts",
    "test": "vitest run",
    "test:unit": "vitest run unit",
    "test:invariants": "vitest run integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.40.0",
    "exceljs": "^4.4.0",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
