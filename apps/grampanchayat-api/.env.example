PORT=3005
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
#
# Supabase gives you two connection strings:
#
# 1. Direct connection (port 5432) — use this for:
#    - drizzle-kit generate / migrate / push
#    - Local development (no pooler needed)
#
# 2. Transaction pooler (port 6543) — use this for:
#    - Production runtime (Express server)
#    - Must set prepare:false in postgres.js (already done in db/index.ts)
#
# In development, the direct URL works fine for both.
# In production, use pooler URL for DATABASE_URL and direct URL for migrations.
#
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_SECRET=change_me_at_least_32_chars_long_secret
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=change_me_different_at_least_32_chars_long
REFRESH_TOKEN_EXPIRY=7d

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://[project-ref].supabase.co
# Use service_role key — NEVER the anon key. Never expose to client.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3004
