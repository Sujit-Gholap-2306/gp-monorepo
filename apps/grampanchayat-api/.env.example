PORT=3005
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in. Get URI from Supabase → Project Settings → Database.
# Use direct :5432 for drizzle-kit migrate; pooler :6543 is ok for the running API.
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres

DATABASE_URL=

# ─── Auth (generate long random strings; min 16 chars each) ─────────────────
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=7d

# ─── Supabase (Project Settings → API) ───────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── CORS (your Next.js app origin) ──────────────────────────────────────────
CORS_ORIGIN=http://localhost:3004
